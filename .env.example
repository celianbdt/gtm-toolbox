# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Site URL — set to the production Vercel URL to ensure Magic Link emails
# redirect to the correct origin instead of localhost.
# Example: https://gtm-toolbox.vercel.app
# Leave unset in local development (falls back to window.location.origin).
NEXT_PUBLIC_SITE_URL=https://<your-vercel-url>.vercel.app

# AI providers (optional, depending on features used)
ANTHROPIC_API_KEY=<anthropic-api-key>
OPENAI_API_KEY=<openai-api-key>
